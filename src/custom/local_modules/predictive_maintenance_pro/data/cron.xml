<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- ================================================================
             Cron diario: verificar umbrales de mantenimiento
             ================================================================ -->
        <record id="ir_cron_check_maintenance_alerts" model="ir.cron">
            <field name="name">PMP: Verificar Umbrales de Mantenimiento</field>
            <field name="model_id" ref="fleet.model_fleet_vehicle"/>
            <field name="state">code</field>
            <field name="code">vehicles = env['fleet.vehicle'].search([('active', '=', True)])
vehicles._check_maintenance_alerts()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active">True</field>
            <field name="user_id" ref="base.user_root"/>
        </record>

    </data>
</odoo>
