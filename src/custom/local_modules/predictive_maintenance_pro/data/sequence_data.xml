<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- Secuencia para órdenes de mantenimiento -->
        <record id="seq_pmp_maintenance_order" model="ir.sequence">
            <field name="name">Orden de Mantenimiento Predictivo</field>
            <field name="code">pmp.maintenance.order</field>
            <field name="prefix">MNT/%(year)s/%(month)s/</field>
            <field name="padding">4</field>
            <field name="company_id" eval="False"/>
        </record>

    </data>
</odoo>
